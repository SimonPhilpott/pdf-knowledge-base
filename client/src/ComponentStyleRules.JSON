{
  "system": "Knowledge Base",
  "version": "1.3.0",
  "tokens": {
    "spacing": {
      "xs": "var(--space-xs) (4px)",
      "sm": "var(--space-sm) (8px)",
      "md": "var(--space-md) (16px)",
      "lg": "var(--space-lg) (24px)",
      "xl": "var(--space-xl) (32px)",
      "2xl": "var(--space-2xl) (48px)"
    },
    "radius": {
      "sm": "var(--radius-sm) (6px)",
      "md": "var(--radius-md) (10px)",
      "lg": "var(--radius-lg) (16px)",
      "xl": "var(--radius-xl) (24px)",
      "full": "var(--radius-full) (9999px)"
    },
    "glass": {
      "blur_heavy": "40px",
      "blur_light": "20px",
      "border": "var(--glass-border)",
      "bg": "var(--glass-bg)"
    },
    "themes": {
      "light_oatmeal": {
        "bg_primary": "#F5F1E9",
        "bg_secondary": "#FBF9F6",
        "text_primary": "#2D2924",
        "accent_bronze": "#8C7355",
        "accent_gold": "#D4C4A8"
      },
      "dark_classic": {
        "bg_primary": "#0a0e1a",
        "accent_indigo": "#6366f1"
      }
    }
  },
  "components": {
    "buttons": {
      "description": "Functional triggers categorized by impact level.",
      "global_behavior": {
        "transition": "all var(--transition-base)",
        "hover_border_color": "var(--glass-border-hover)",
        "icon_hover_transform": "scale(1.15)"
      },
      "variants": {
        "prominent": {
          "description": "High-impact triggers for primary user goals.",
          "classes": [
            "new-chat-btn",
            "toolbar-btn.primary",
            "auth-btn.login"
          ],
          "specs": {
            "background": "var(--gradient-primary)",
            "shadow": "var(--shadow-glow)",
            "icon_size": 14,
            "padding": "10px 18px",
            "font_weight": 700
          }
        },
        "structural": {
          "description": "Navigation and high-level workflow actions.",
          "classes": [
            "sidebar-action-btn",
            "toolbar-btn",
            "surprise-btn"
          ],
          "specs": {
            "background": "var(--bg-tertiary)",
            "border": "1px solid var(--glass-border)",
            "hover_bg": "var(--glass-bg-light)",
            "icon_size": 14,
            "padding": "10px 16px"
          }
        },
        "status_actions": {
          "description": "Contextual or state-dependent triggers.",
          "classes": [
            "auth-btn.logout",
            "sync-btn",
            "topic-chip"
          ],
          "specs": {
            "padding": "6px 12px",
            "radius": "var(--radius-md)",
            "font_size": "11px",
            "font_weight": 600
          }
        },
        "toolbar_compact": {
          "description": "Micro-actions within toolbars or editors.",
          "classes": [
            "catalog-action-btn",
            "canvas-action-btn",
            "tool-btn"
          ],
          "specs": {
            "icon_size": 14,
            "padding": "6px",
            "radius": "var(--radius-sm)"
          }
        },
        "segment_toggles": {
          "description": "Multi-option selectors with a unified pill-style background.",
          "classes": [
            "tone-switcher",
            "mode-switcher",
            "gem-toggle",
            "theme-toggle-container"
          ],
          "specs": {
            "container_radius": "var(--radius-full)",
            "container_padding": "2px",
            "item_radius": "var(--radius-full)",
            "item_padding": "8px 16px",
            "between_item_gap": "1px",
            "internal_icon_gap": "8px",
            "active_background": "var(--gradient-primary)",
            "active_text": "white",
            "font_size": "11px",
            "font_weight": 600
          }
        }
      }
    },
    "messages": {
      "description": "Chat and conversational UI elements with directional corner styling.",
      "variants": {
        "user_prompt": {
          "description": "Messages sent by the user. Distinctive bottom-right sharp corner.",
          "classes": [
            "message.user .message-content",
            "user-message-style"
          ],
          "specs": {
            "background": "var(--accent-indigo)",
            "color": "white",
            "radius": "var(--radius-lg)",
            "border_bottom_right_radius": "var(--space-xs)"
          }
        },
        "ai_reply": {
          "description": "Messages generated by the AI. Distinctive bottom-left sharp corner.",
          "classes": [
            "message.assistant .message-content",
            "ai-message-style"
          ],
          "specs": {
            "background": "var(--glass-bg)",
            "border": "1px solid var(--glass-border)",
            "radius": "var(--radius-lg)",
            "border_bottom_left_radius": "var(--space-xs)"
          }
        }
      }
    },
    "global_actions": {
      "description": "Universal app actions for hard-coded consistency.",
      "standard_close": {
        "classes": [
          "global-close-btn"
        ],
        "icon": "X",
        "icon_size": 18,
        "padding": "8px",
        "radius": "var(--radius-md)",
        "hover_color": "var(--status-red)",
        "hover_bg": "rgba(239, 68, 68, 0.1)"
      },
      "standard_search": {
        "classes": [
          "catalog-search",
          "topic-search",
          "topic-search-wrapper"
        ],
        "icon_size": 14,
        "input_font": "12px",
        "padding": "8px 12px",
        "radius": "var(--radius-full)",
        "background": "rgba(0, 0, 0, 0.2)"
      }
    },
    "data_structures": {
      "file_explorer": {
        "description": "Hierarchical tree views for library management.",
        "specs": {
          "indent_step": "16px",
          "item_height": "36px",
          "icon_spacing": "var(--space-sm)",
          "badge_radius": "4px",
          "font_size": "13px"
        },
        "states": {
          "selected": "color-mix(in srgb, var(--accent-indigo), transparent 90%)",
          "hover": "var(--glass-bg-light)",
          "ai_accent": "var(--accent-indigo)"
        }
      }
    },
    "hover_components": {
      "cursor_tooltip": {
        "description": "Minimal text block following cursor for instant context.",
        "specs": {
          "background": "var(--glass-bg)",
          "blur": "12px",
          "padding": "8px 12px",
          "font_size": "11px",
          "max_width": "240px",
          "z_index": 1000000
        }
      },
      "cursor_popover": {
        "description": "Advanced floating window for rich/dynamic content.",
        "specs": {
          "width": "320px",
          "background": "var(--bg-secondary)",
          "radius": "var(--radius-xl)",
          "header_padding": "12px 16px",
          "content_padding": "16px",
          "shadow": "var(--shadow-xl)"
        }
      }
    },
    "modals": {
      "description": "Full-screen overlays and centered windows.",
      "styles": {
        "window_radius": "var(--radius-xl)",
        "header_padding": "var(--space-md) var(--space-xl)",
        "content_padding": "var(--space-lg) var(--space-xl)",
        "background": "var(--bg-secondary)",
        "border": "1px solid var(--glass-border)",
        "backdrop_blur": "40px"
      }
    },
    "interactions": {
      "horizontal_drag_scroll": {
        "description": "Mouse-drag horizontal navigation for segment toggles on desktop.",
        "specs": {
          "cursor_idle": "grab",
          "cursor_active": "grabbing",
          "scroll_speed_multiplier": 2,
          "click_prevention_during_drag": true,
          "motion_threshold": "5px"
        }
      },
      "mobile_stability_overrides": {
        "description": "Fail-safe layout grounding using inline React styles for mobile viewports.",
        "specs": {
          "sidebar_offset": "margin-top: var(--topbar-height) !important",
          "prompt_wrapping": "flex-wrap: wrap, flex-basis: 100% (textarea)",
          "breakpoint": "768px (CSS) / 1024px (JS detection)"
        }
      }
    },
    "layout_z_index": {
      "app_topbar": 9999,
      "tooltips": 1000000,
      "side_panels": 1000,
      "modals": 2000
    },
    "manifest_visuals": {
      "description": "Structural color hierarchy for System Manifests and rule lists.",
      "specs": {
        "heading_2": "var(--manifest-heading) / 800 weight",
        "subheading_bold": "var(--manifest-subheading) / 700 weight",
        "body_text": "var(--manifest-text) / 100% opacity in Dark Mode"
      }
    }
  }
}