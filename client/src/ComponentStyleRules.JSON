{
  "system": "Knowledge Base",
  "version": "1.3.0",
  "tokens": {
    "spacing": {
      "xs": "var(--space-xs) (4px)",
      "sm": "var(--space-sm) (8px)",
      "md": "var(--space-md) (16px)",
      "lg": "var(--space-lg) (24px)",
      "xl": "var(--space-xl) (32px)",
      "2xl": "var(--space-2xl) (48px)"
    },
    "radius": {
      "sm": "var(--radius-sm) (6px)",
      "md": "var(--radius-md) (10px)",
      "lg": "var(--radius-lg) (16px)",
      "xl": "var(--radius-xl) (24px)",
      "full": "var(--radius-full) (9999px)"
    },
    "glass": {
      "blur_heavy": "40px",
      "blur_light": "20px",
      "border": "var(--glass-border)",
      "bg": "var(--glass-bg)"
    },
    "themes": {
      "light_oatmeal": {
        "bg_primary": "#F5F1E9",
        "bg_secondary": "#FBF9F6",
        "text_primary": "#2D2924",
        "accent_bronze": "#8C7355",
        "accent_gold": "#D4C4A8"
      },
      "dark_classic": {
        "bg_primary": "#0a0e1a",
        "accent_indigo": "#6366f1"
      }
    },
    "typography": {
      "headings": {
        "h1": "28px / 900 weight / -0.04em letter-spacing",
        "h2": "22px / 800 weight / -0.02em letter-spacing",
        "h3": "14px / 700 weight / 0.1em tracking-widest",
        "manifest_primary": "var(--manifest-heading) / 800 weight",
        "manifest_secondary": "var(--manifest-subheading) / 700 weight"
      },
      "body": {
        "standard": "14px / 1.6 line-height / 500 weight",
        "compact": "12px / 1.5 line-height / 600 weight",
        "micro": "10px / 1.2 line-height / 700 weight",
        "manifest_text": "var(--manifest-text) / 1.6 line-height"
      }
    }
  },
  "components": {
    "buttons": {
      "description": "Functional triggers categorized by impact level.",
      "global_behavior": {
        "transition": "all var(--transition-base)",
        "hover_border_color": "var(--glass-border-hover)",
        "icon_hover_transform": "scale(1.15)"
      },
      "variants": {
        "prominent": {
          "description": "High-impact triggers for primary user goals.",
          "classes": [
            "new-chat-btn",
            "toolbar-btn.primary",
            "auth-btn.login"
          ],
          "specs": {
            "background": "var(--gradient-primary)",
            "shadow": "var(--shadow-glow)",
            "icon_size": 14,
            "padding": "10px 18px",
            "font_weight": 700
          }
        },
        "structural": {
          "description": "Navigation and high-level workflow actions.",
          "classes": [
            "sidebar-action-btn",
            "toolbar-btn",
            "surprise-btn"
          ],
          "specs": {
            "background": "var(--bg-tertiary)",
            "border": "1px solid var(--glass-border)",
            "hover_bg": "var(--glass-bg-light)",
            "icon_size": 14,
            "padding": "10px 16px"
          }
        },
        "status_actions": {
          "description": "Contextual or state-dependent triggers.",
          "classes": [
            "auth-btn.logout",
            "sync-btn",
            "topic-chip"
          ],
          "specs": {
            "padding": "6px 12px",
            "radius": "var(--radius-md)",
            "font_size": "11px",
            "font_weight": 600
          }
        },
        "toolbar_compact": {
          "description": "Micro-actions within toolbars or editors.",
          "classes": [
            "catalog-action-btn",
            "canvas-action-btn",
            "tool-btn"
          ],
          "specs": {
            "icon_size": 14,
            "padding": "6px",
            "radius": "var(--radius-sm)"
          }
        },
        "segment_toggles": {
          "description": "Multi-option selectors with a unified pill-style background. Used for Persona, Tone, and Model switching.",
          "classes": [
            "tone-switcher",
            "mode-switcher",
            "gem-toggle",
            "theme-toggle-container"
          ],
          "specs": {
            "container_radius": "var(--radius-full)",
            "container_padding": "2px",
            "item_radius": "var(--radius-full)",
            "item_padding": "8px 16px",
            "between_item_gap": "1px",
            "internal_icon_gap": "8px",
            "active_background": "var(--gradient-primary)",
            "active_text": "white",
            "font_size": "11px",
            "font_weight": 600
          }
        }
      }
    },
    "messages": {
      "description": "Chat and conversational UI elements with directional corner styling.",
      "variants": {
        "user_prompt": {
          "description": "Messages sent by the user. Distinctive bottom-right sharp corner.",
          "classes": [
            "message.user .message-content",
            "user-message-style"
          ],
          "specs": {
            "background": "var(--accent-indigo)",
            "color": "white",
            "radius": "var(--radius-lg)",
            "border_bottom_right_radius": "var(--space-xs)"
          }
        },
        "ai_reply": {
          "description": "Messages generated by the AI. Distinctive bottom-left sharp corner.",
          "classes": [
            "message.assistant .message-content",
            "ai-message-style"
          ],
          "specs": {
            "background": "var(--glass-bg)",
            "border": "1px solid var(--glass-border)",
            "radius": "var(--radius-lg)",
            "border_bottom_left_radius": "var(--space-xs)"
          }
        }
      }
    },
    "global_actions": {
      "description": "Universal app actions and persistent utility elements.",
      "classes": [
        "global-close-btn",
        "catalog-search",
        "topic-search"
      ],
      "specs": {
        "close_btn_size": "32px",
        "search_radius": "var(--radius-full)",
        "search_bg": "rgba(0, 0, 0, 0.2)",
        "search_padding": "10px 16px",
        "icon_size": 16
      }
    },
    "data_structures": {
      "description": "Hierarchical and complex data visualisations.",
      "variants": {
        "file_explorer": {
          "description": "Tree views for library management with folder/file nesting.",
          "classes": [
            "folder-item",
            "file-item",
            "subject-tree"
          ],
          "specs": {
            "indent_step": "16px",
            "item_height": "36px",
            "icon_spacing": "12px",
            "badge_radius": "4px",
            "font_size": "13px"
          }
        }
      }
    },
    "hover_components": {
      "description": "Floating elements triggered by user focus for instant context.",
      "variants": {
        "cursor_tooltip": {
          "description": "Minimal context block following cursor.",
          "specs": {
            "background": "var(--glass-bg)",
            "blur": "12px",
            "padding": "8px 12px",
            "font_size": "11px",
            "z_index": 1000000
          }
        },
        "cursor_popover": {
          "description": "Advanced floating window for rich content and metadata.",
          "specs": {
            "width": "320px",
            "background": "var(--bg-secondary)",
            "radius": "var(--radius-xl)",
            "shadow": "var(--shadow-xl)"
          }
        }
      }
    },
    "modals": {
      "description": "Full-screen overlays and centered executive control windows.",
      "classes": [
        "admin-portal",
        "auth-modal",
        "gem-selector-modal"
      ],
      "specs": {
        "window_radius": "var(--radius-xl)",
        "backdrop_blur": "40px",
        "shadow": "var(--shadow-2xl)",
        "border": "1px solid var(--glass-border)"
      }
    },
    "layout_z_index": {
      "description": "Depth registry for absolute layer management.",
      "specs": {
        "tooltips": 1000000,
        "modals": 9000,
        "app_topbar": 1000,
        "side_panels": 500,
        "main_content": 1
      }
    }
  }
}