{
  "version": "1.6.1",
  "project": "Knowledge Base",
  "audit_status": "Production-Locked (Full Restore)",
  "tokens": {
    "themes": {
      "oatmeal": {
        "bg_primary": "#F1EFE9",
        "bg_secondary": "#FBF9F7",
        "bg_tertiary": "#EDE5D8",
        "accent": "#899981",
        "text_primary": "#2E2B27",
        "text_muted": "#6A645D"
      }
    },
    "layout": {
      "topbar_height": "56px",
      "sidebar_width": "260px",
      "topic_panel_width": "320px",
      "status_bar_height": "36px",
      "mobile_breakpoint": "768px"
    },
    "interaction_gestures": {
      "drag_threshold": "5px",
      "scroll_multiplier": 2,
      "press_scale": "0.98",
      "hover_scale": "1.1",
      "click_delay_mask": "50ms"
    },
    "voice_intelligence": {
      "default_lang": "en-GB",
      "engine": "Web Speech API (Google Premium)",
      "stt_auto_submit": true,
      "tts_rate": 1.05,
      "tts_pitch": 1.0,
      "mic_pulse_color": "#ef4444",
      "markdown_stripping": [
        "#",
        "*",
        "_",
        "`",
        "[]",
        "()"
      ]
    },
    "motion": {
      "transition_fast": "150ms cubic-bezier(0.4, 0, 0.2, 1)",
      "transition_base": "250ms cubic-bezier(0.4, 0, 0.2, 1)",
      "transition_slow": "400ms cubic-bezier(0.4, 0, 0.2, 1)",
      "hover_timing": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    },
    "effects": {
      "shadow_glow": "0 0 20px rgba(137, 153, 129, 0.15)",
      "shadow_glow_hover": "0 0 30px rgba(137, 153, 129, 0.25)",
      "glass_blur": "blur(30px)",
      "glass_blur_deep": "blur(40px)"
    },
    "opacity": {
      "glass_overlay": "0.75",
      "glass_border": "0.1",
      "glass_border_hover": "0.25",
      "ghost_icon": "0.8"
    },
    "typography": {
      "headings": {
        "manifest_heading": "24px / 800 / var(--manifest-heading)",
        "manifest_subheading": "18px / 700 / var(--manifest-subheading)",
        "section_title": "11px / 900 / 4px letter-spacing",
        "card_title": "14px / 700"
      },
      "body": {
        "manifest_text": "14px / 1.6 / 500 / var(--manifest-text)",
        "interface_medium": "12px / 1.5 / 600",
        "interface_regular": "12px / 1.5 / 400",
        "caption": "11px / 1.5 / 700"
      }
    }
  },
  "components": {
    "buttons": {
      "description": "Premium glassmorphism actions with icon-centric interaction protocols.",
      "classes": [
        "sync-btn",
        "glass-btn"
      ],
      "interaction": {
        "hover_background": "var(--glass-bg-light)",
        "hover_border": "var(--glass-border-hover)",
        "press_state": "scale(0.98)",
        "transition": "var(--transition-fast)"
      },
      "variants": {
        "status_action": {
          "specs": {
            "padding": "4px 12px",
            "background": "var(--bg-tertiary)",
            "border": "1px solid var(--glass-border)",
            "radius": "var(--radius-full)",
            "font_size": "11px",
            "font_weight": 600,
            "icon_size": 14
          }
        },
        "primary_action": {
          "specs": {
            "padding": "10px 20px",
            "background": "var(--gradient-primary)",
            "radius": "var(--radius-full)",
            "active_text": "white",
            "icon_size": 16
          }
        },
        "voice_mic": {
          "specs": {
            "active_color": "#ef4444",
            "active_animation": "pulse 2s infinite",
            "secondary_animation": "spin 3s linear infinite (Sparkles)"
          }
        }
      }
    },
    "segment_toggles": {
      "description": "Production-accurate persona switchers. Track-based geometry with floating active pills.",
      "specs": {
        "container_padding": "3px",
        "container_radius": "var(--radius-full)",
        "container_background": "var(--bg-tertiary)",
        "item_padding": "8px 16px",
        "item_radius": "var(--radius-full)",
        "active_background": "var(--gradient-primary)",
        "active_text": "white",
        "active_shadow": "var(--shadow-glow)",
        "font_size": "11px",
        "font_weight": 700,
        "between_item_gap": "2px",
        "internal_icon_gap": "8px",
        "icon_size": 14,
        "icon_opacity": 0.8
      }
    },
    "messages": {
      "description": "Static document intelligence blocks with flat hover states.",
      "variants": {
        "user_prompt": {
          "specs": {
            "background": "var(--bg-elevated)",
            "radius": "20px",
            "border_bottom_right_radius": "4px"
          }
        },
        "ai_response": {
          "specs": {
            "background": "var(--bg-secondary)",
            "border": "1px solid var(--glass-border)",
            "radius": "20px",
            "border_bottom_left_radius": "4px"
          }
        }
      }
    },
    "hover_components": {
      "description": "Viewport-intelligent floating nodes that follow the cursor context.",
      "protocol": {
        "positioning": "fixed cursor-relative",
        "offset": "12px",
        "viewport_intelligence": "quadrant-aware flipping"
      },
      "variants": {
        "context_tooltip": {
          "specs": {
            "padding": "10px 14px",
            "background": "var(--bg-secondary)",
            "blur": "30px",
            "font_size": "11px",
            "shadow": "var(--shadow-lg)"
          }
        },
        "cursor_popover": {
          "specs": {
            "width": "320px",
            "header_bg": "rgba(255, 255, 255, 0.02)",
            "header_font": "10px / 900 / uppercase",
            "body_padding": "16px",
            "radius": "var(--radius-xl)",
            "shadow": "var(--shadow-xl)"
          }
        }
      }
    },
    "file_explorer": {
      "description": "High-fidelity subject navigation with indentation logic.",
      "specs": {
        "indent_step": "16px",
        "item_radius": "4px",
        "active_color": "var(--accent-indigo)"
      }
    },
    "administrative_overlays": {
      "description": "High-priority contextual windows for system configuration and authentication. Employs a 40px backdrop blur and absolute z-index priority (9000+) to isolate critical administrative tasks from the primary research workspace.",
      "classes": [
        "admin-portal-overlay",
        "auth-gateway",
        "intelligence-drawer"
      ],
      "specs": {
        "window_radius": "var(--radius-xl)",
        "backdrop_blur": "40px",
        "shadow": "var(--shadow-2xl)",
        "border": "1px solid var(--glass-border)"
      }
    },
    "layout_z_index": {
      "description": "Depth registry for absolute layer management.",
      "specs": {
        "tooltips": 1000000,
        "modals": 9000,
        "app_topbar": 1000,
        "side_panels": 500
      }
    }
  },
  "mobile_overrides": {
    "chat_input": {
      "flex_wrap": "wrap",
      "padding": "12px",
      "textarea_basis": "100%",
      "tools_border": "none"
    },
    "interactions": {
      "hover": "disabled",
      "scroll": "native momentum",
      "drag": "touch-action: pan-y"
    }
  }
}