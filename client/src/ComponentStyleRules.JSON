{
  "version": "1.4.0",
  "project": "Knowledge Base",
  "tokens": {
    "themes": {
      "oatmeal": {
        "primary": "#F1EFE9",
        "secondary": "#FBF9F7",
        "accent": "#899981",
        "text": "#2E2B27"
      }
    },
    "layout": {
      "topbar_height": "56px",
      "sidebar_width": "260px",
      "topic_panel_width": "320px",
      "status_bar_height": "36px"
    },
    "motion": {
      "transition_fast": "150ms cubic-bezier(0.4, 0, 0.2, 1)",
      "transition_base": "250ms cubic-bezier(0.4, 0, 0.2, 1)",
      "transition_slow": "400ms cubic-bezier(0.4, 0, 0.2, 1)",
      "hover_timing": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    },
    "effects": {
      "shadow_glow": "0 0 20px rgba(137, 153, 129, 0.15)",
      "shadow_glow_hover": "0 0 30px rgba(137, 153, 129, 0.25)",
      "glass_blur": "blur(30px)",
      "glass_blur_deep": "blur(40px)"
    },
    "opacity": {
      "glass_overlay": "0.75",
      "glass_border": "0.1",
      "glass_border_hover": "0.25",
      "ghost_icon": "0.4"
    },
    "typography": {
      "headings": {
        "manifest_heading": "24px / 800 / var(--manifest-heading)",
        "manifest_subheading": "18px / 700 / var(--manifest-subheading)",
        "section_title": "11px / 900 / 4px letter-spacing",
        "card_title": "14px / 700"
      },
      "body": {
        "manifest_text": "14px / 1.6 / 500 / var(--manifest-text)",
        "interface_medium": "12px / 1.5 / 600",
        "interface_regular": "12px / 1.5 / 400",
        "caption": "10px / 1.4 / 700 / uppercase"
      }
    }
  },
  "components": {
    "buttons": {
      "description": "Premium glassmorphism actions with icon-centric interaction protocols.",
      "classes": [
        "glass-btn",
        "accent-btn"
      ],
      "interaction": {
        "hover_container": "border-color shift only",
        "hover_icon": "scale(1.2) transform",
        "transition": "var(--transition-fast)"
      },
      "variants": {
        "primary_action": {
          "specs": {
            "padding": "10px 20px",
            "background": "var(--gradient-primary)",
            "radius": "var(--radius-full)",
            "active_text": "white",
            "icon_size": 16,
            "internal_icon_gap": "10px"
          }
        },
        "secondary_ghost": {
          "specs": {
            "padding": "8px 16px",
            "background": "transparent",
            "border": "1px solid var(--glass-border)",
            "radius": "12px",
            "icon_size": 14
          }
        }
      }
    },
    "segment_toggles": {
      "description": "Quadrant-style persona switchers with ghost-icon states.",
      "specs": {
        "container_padding": "4px",
        "container_radius": "14px",
        "item_padding": "6px 12px",
        "item_radius": "10px",
        "active_background": "var(--bg-primary)",
        "active_text": "var(--accent-indigo)",
        "font_size": "10px",
        "font_weight": 800,
        "between_item_gap": "2px",
        "internal_icon_gap": "6px"
      },
      "interaction": {
        "unselected_state": "opacity(0.4) icon",
        "transition": "background 0.2s ease"
      }
    },
    "messages": {
      "description": "Static document intelligence blocks with flat hover states.",
      "variants": {
        "user_prompt": {
          "specs": {
            "background": "var(--bg-elevated)",
            "radius": "20px",
            "border_bottom_right_radius": "4px"
          }
        },
        "ai_response": {
          "specs": {
            "background": "var(--bg-secondary)",
            "border": "1px solid var(--glass-border)",
            "radius": "20px",
            "border_bottom_left_radius": "4px"
          }
        }
      },
      "interaction": {
        "hover": "none (static)",
        "transition": "none"
      }
    },
    "file_explorer": {
      "description": "Hierarchical document trees with interactive node highlights.",
      "specs": {
        "indent_step": "16px",
        "item_height": "32px",
        "active_bg": "var(--accent-indigo)1a",
        "active_text": "var(--accent-indigo)"
      }
    },
    "hover_components": {
      "description": "Viewport-intelligent floating nodes that follow the cursor context.",
      "protocol": {
        "positioning": "fixed cursor-relative",
        "offset": "24px",
        "viewport_intelligence": "quadrant-aware flipping",
        "boundary_safety": "10px safety margin"
      },
      "variants": {
        "context_tooltip": {
          "specs": {
            "padding": "8px 12px",
            "blur": "20px",
            "font_size": "11px"
          }
        },
        "cursor_popover": {
          "specs": {
            "width": "320px",
            "blur": "40px",
            "radius": "var(--radius-xl)",
            "shadow": "var(--shadow-xl)"
          }
        }
      }
    }
  },
  "layout_z_index": {
    "description": "Architectural depth hierarchy for modal and portal layering.",
    "specs": {
      "cursor_hover": 2147483647,
      "modals": 1000,
      "app_topbar": 500,
      "side_panels": 100,
      "base": 0
    }
  }
}